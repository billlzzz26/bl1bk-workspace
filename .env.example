# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL="file:./dev.db"

# ===========================================
# AUTHENTICATION CONFIGURATION
# ===========================================
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:5173"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# ===========================================
# AI PROVIDERS CONFIGURATION
# ===========================================

# OpenAI
OPENAI_API_KEY="sk-your-openai-api-key"

# Google AI (Gemini)
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# Anthropic (Claude)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Cohere
COHERE_API_KEY="your-cohere-api-key"

# Hugging Face
HUGGINGFACE_API_KEY="your-huggingface-api-key"

# Replicate
REPLICATE_API_TOKEN="your-replicate-api-token"

# Together AI
TOGETHER_API_KEY="your-together-api-key"

# Groq
GROQ_API_KEY="your-groq-api-key"

# Perplexity
PERPLEXITY_API_KEY="your-perplexity-api-key"

# Mistral
MISTRAL_API_KEY="your-mistral-api-key"

# ===========================================
# OPIK CONFIGURATION (AI Observability)
# ===========================================
OPIK_API_KEY="your-opik-api-key"
OPIK_PROJECT_NAME="unified-ai-workspace"
OPIK_WORKSPACE="your-opik-workspace"
OPIK_BASE_URL="https://www.comet.com/opik/api"

# ===========================================
# MCP (Model Context Protocol) CONFIGURATION
# ===========================================
MCP_SERVER_URL="http://localhost:8000"
MCP_API_KEY="your-mcp-api-key"

# ===========================================
# AGENT & SANDBOX CONFIGURATION
# ===========================================
AGENT_SANDBOX_URL="http://localhost:8080"
AGENT_API_KEY="your-agent-api-key"

# ===========================================
# SECURITY & ENCRYPTION
# ===========================================
ENCRYPTION_KEY="your-32-character-encryption-key-here"
JWT_SECRET="your-jwt-secret-key"

# ===========================================
# VECTOR DATABASE (for RAG)
# ===========================================
PINECONE_API_KEY="your-pinecone-api-key"
PINECONE_ENVIRONMENT="your-pinecone-environment"
PINECONE_INDEX="unified-ai-workspace"

# Alternative: Weaviate
WEAVIATE_URL="http://localhost:8080"
WEAVIATE_API_KEY="your-weaviate-api-key"

# ===========================================
# REDIS (for caching and sessions)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# EMAIL CONFIGURATION (for notifications)
# ===========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# ===========================================
# DEVELOPMENT & DEBUGGING
# ===========================================
NODE_ENV="development"
DEBUG="true"
LOG_LEVEL="info"

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================
VERCEL_URL=""
RAILWAY_URL=""
RENDER_URL=""
